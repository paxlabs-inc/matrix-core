{
  "ignorePatterns": [
    { "pattern": "^http://localhost" },
    { "pattern": "^https://localhost" },
    { "pattern": "^http://127\\.0\\.0\\.1" },
    { "pattern": "^https://github\\.com/paxlabs-inc/matrix-core/pull/" },
    { "pattern": "^matrix://" },
