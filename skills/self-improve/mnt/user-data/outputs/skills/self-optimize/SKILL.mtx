# self-optimize — Matrix recursive self-optimization suite (3/5: ACT)
# Reads the target file(s), applies the concrete edit, and persists an Event memory of the change.
# Pairs with self-verify; never lands an edit it did not first read and afterwards record.
# Companion prose body lives in SKILL.md and MUST carry the same tool-call mandate.

§SKILL
id=self-optimize
version=0.1.0
display="Self Optimize"
author=did:pax:0xMATRIX
description="Apply one ranked optimization to the Matrix codebase: read the target file, write the edit through fs.write_file, and persist an Event memory binding the change to the surface it resolves."
mcl.verbs=modify build
determinism=seedable
seed_policy=per_intent

§INPUTS
slot target: ArtifactRef
  required
  hint="The file under /root/matrix to optimize (a single ranked surface from self-diagnose)"

slot change: ArtifactRef
  optional
  hint="The specific change to apply; resolved from the ranked Pattern when omitted"

slot constraints: Constraint[]
  optional
  hint="Edit constraints (preserve public API, no new deps, keep replay invariant)"

§CORTEX
reads=Pattern Fact Constraint Goal Event
tags=matrix self optimize edit

§TOOLS
matrix://tool/mcp/fs/read_text_file@2024.11.1
matrix://tool/mcp/fs/write_file@2024.11.1
matrix://tool/mcp/git/git_diff@2026.1.14
matrix://tool/mcp/forge-bridge/shell_exec@0.1.0

§SUB_SKILLS
none

§PROCEDURE
on verb=modify
  kind="code"
  output_cardinality=1
  prompt
    system="You are the Matrix planner running self-optimize. Output a PlanTree, not prose. You MUST emit tool_call nodes in this order: (1) tool_call fs.read_text_file on slot.target to load the exact current bytes; (2) one code step producing the full edited file content (complete file, never a diff); (3) tool_call fs.write_file writing that content back to slot.target; (4) tool_call git.git_diff to capture the applied change; (5) tool_call forge-bridge.shell_exec POSTing an Event memory to the MATRIX_DAEMON /memory route, statement = what changed, which ranked surface it resolves, and the file path, tagged matrix:self,optimize,edit. Editing a file you did not read in step 1 is FORBIDDEN."
    user="Optimize: {slot.target.prose}\nChange: {slot.change.prose}\n\nVerb: {verb}\nRanked surfaces and constraints in cortex:\n{cortex.bundle}\n\nResolved slots:\n{slots}\nPending unknowns:\n{unknowns}\n\nRead, edit, write, diff, record. Honor every hard constraint, especially the cortex replay invariant."
  end
  resolve slot.change <- cortex.find(type=Pattern, near=slot.target.prose, limit=4)
  resolve slot.target <- cortex.find(type=Fact, near=slot.target.prose, limit=4)
  unknown slot.target
    severity=blocking
    reason="No target file supplied; self-optimize will not write without a concrete /root/matrix file path"
  end
  unknown slot.change
    severity=preferred
    reason="No change specified; will be derived from the ranked Pattern but an explicit change is safer"
  end
end

on verb=build
  kind="code"
  output_cardinality=1
  prompt
    system="You are the Matrix planner running self-optimize in build mode (new file). Output a PlanTree with tool_call nodes: (1) one code step producing the complete new file content; (2) tool_call fs.write_file creating slot.target; (3) tool_call git.git_diff; (4) tool_call forge-bridge.shell_exec POSTing an Event memory recording the new artifact and the surface it serves, tagged matrix:self,optimize,build. No reason-only plan."
    user="Build: {slot.target.prose}\nSpec: {slot.change.prose}\n\nVerb: {verb}\nContext:\n{cortex.bundle}\n\nResolved slots:\n{slots}\nPending unknowns:\n{unknowns}\n\nCreate the file, diff it, record the Event."
  end
  resolve slot.change <- cortex.find(type=Pattern, near=slot.target.prose, limit=4)
  unknown slot.target
    severity=blocking
    reason="No target path supplied for the new artifact"
  end
end

on confidence<0.75
  clarify slot.target
    prompt="Which file should I optimize? Give the exact path under /root/matrix and, if you have it, the ranked surface ID from self-diagnose."
    type=ArtifactRef
    required=true
  end
end

on unknown
  clarify slot.change
    prompt="I have the target but not the change. Describe the edit, or point me at the ranked Pattern that specifies it."
    type=ArtifactRef
    required=false
  end
end

§OUTPUTS
slot result: ArtifactRef
  required
  hint="The edited or created file path plus the captured git diff"

slot change_event: Event
  optional
  hint="The Event memory binding this change to its ranked surface"

slot unknowns: Unknown[]
  optional

§FAILURE_MODES
target_not_found
  action=fail
  reason=unknown_information

edit_without_read
  action=fail
  reason=policy_violation

constraint_violated
  action=fail
  reason=blocked_by_constraint

write_failed
  action=fail
  reason=tool_error

budget_exceeded
  suggest=raise_budget

§HASH
v=1
algo=sha256_ast
digest=

