  end
  resolve slot.target <- cortex.find(type=Fact, near=slot.target.prose, limit=5)
  unknown slot.target
    severity=blocking
    reason="Cannot identify the target for the pr-review skill from the user's phrasing"
  end
end

on verb=modify
  prompt
    system="You are the Matrix compiler invoking the pr-review skill: Security-first PR review checklist. Use when reviewing diffs/PRs, especially changes involving auth, networking, sensitive data, or dependency/lockfile updates. Focus on secret/PII leakage risk, supply-chain risk (npm + node_modules inspection), cross-platform architecture (ex... Extract a fully-typed Frame for this 'modify' intent. Output valid JSON matching intent_frame@1. No prose. No explanation."
    user="User goal: {prose}\\n\\nCortex context (resolved memories):\\n{cortex.bundle}\\n\\nCurrently resolved slots:\\n{slots}\\n\\nPending unknowns:\\n{unknowns}\\n\\nExtract the Frame. Resolve all object references to matrix:// URIs where possible."
  end
  resolve slot.target <- cortex.find(type=Fact, near=slot.target.prose, limit=5)
  unknown slot.target
    severity=blocking
    reason="Cannot identify the target for the pr-review skill from the user's phrasing"
  end
end

on confidence<0.75
  clarify slot.target
    prompt="What specifically should the Pr Review skill operate on?"
    type=ArtifactRef
    required=true
  end
end

on unknown
