§TOOLS
none

§SUB_SKILLS
none

§PROCEDURE
on verb=analyze
  prompt
    system="You are the Matrix compiler invoking the regex-vs-llm-structured-text skill: Decision framework for choosing between regex and LLM when parsing structured text — start with regex, add LLM only for low-confidence edge cases. Extract a fully-typed Frame for this 'analyze' intent. Output valid JSON matching intent_frame@1. No prose. No explanation."
    user="User goal: {prose}\\n\\nCortex context (resolved memories):\\n{cortex.bundle}\\n\\nCurrently resolved slots:\\n{slots}\\n\\nPending unknowns:\\n{unknowns}\\n\\nExtract the Frame. Resolve all object references to matrix:// URIs where possible."
  end
  resolve slot.target <- cortex.find(type=Fact, near=slot.target.prose, limit=5)
  unknown slot.target
    severity=blocking
    reason="Cannot identify the target for the regex-vs-llm-structured-text skill from the user's phrasing"
  end
end

on confidence<0.75
  clarify slot.target
    prompt="What specifically should the Regex Vs Llm Structured Text skill operate on?"
    type=ArtifactRef
    required=true
  end
end

on unknown
  clarify slot.target
    prompt="I could not find a matching reference in your memories. Can you describe the target more specifically?"
    type=ArtifactRef
    required=true
  end
end

§OUTPUTS
slot result: ArtifactRef
  required
  hint="The artifact, plan, or report produced by this skill"

