§SKILL
id=cost-aware-llm-pipeline
version=0.1.0
display="Cost Aware Llm Pipeline"
author=did:pax:0xPLACEHOLDER
description="Cost optimization patterns for LLM API usage — model routing by task complexity, budget tracking, retry logic, and prompt caching."
mcl.verbs=monitor
determinism=seedable
seed_policy=per_intent

§INPUTS
slot target: ArtifactRef
  required
  hint="The artifact, system, or topic this skill should be applied to"

slot constraints: Constraint[]
  optional
  hint="Hard constraints the skill output must satisfy"

§CORTEX
reads=Fact Goal Pattern Event Constraint Preference
tags=cost aware llm pipeline

§TOOLS
none

§SUB_SKILLS
none

§PROCEDURE
on verb=monitor
  prompt
    system="You are the Matrix compiler invoking the cost-aware-llm-pipeline skill: Cost optimization patterns for LLM API usage — model routing by task complexity, budget tracking, retry logic, and prompt caching. Extract a fully-typed Frame for this 'monitor' intent. Output valid JSON matching intent_frame@1. No prose. No explanation."
    user="User goal: {prose}\\n\\nCortex context (resolved memories):\\n{cortex.bundle}\\n\\nCurrently resolved slots:\\n{slots}\\n\\nPending unknowns:\\n{unknowns}\\n\\nExtract the Frame. Resolve all object references to matrix:// URIs where possible."
  end
  resolve slot.target <- cortex.find(type=Fact, near=slot.target.prose, limit=5)
  unknown slot.target
    severity=blocking
    reason="Cannot identify the target for the cost-aware-llm-pipeline skill from the user's phrasing"
  end
end

on confidence<0.75
  clarify slot.target
    prompt="What specifically should the Cost Aware Llm Pipeline skill operate on?"
    type=ArtifactRef
    required=true
  end
end

on unknown
  clarify slot.target
    prompt="I could not find a matching reference in your memories. Can you describe the target more specifically?"
    type=ArtifactRef
    required=true
  end
end

§OUTPUTS
slot result: ArtifactRef
  required
  hint="The artifact, plan, or report produced by this skill"

slot unknowns: Unknown[]
  optional

§FAILURE_MODES
