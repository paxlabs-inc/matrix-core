# Most configuration now lives in tachyon.config.kvx (see tachyon.config.kvx.example).
# Environment variables override the kvx file. Common overrides:

TACHYON_CONFIG=tachyon.config.kvx
TACHYON_API_ADDR=:8645
TACHYON_PROJECT_ROOT=
TACHYON_ARTIFACTS_DIR=artifacts
TACHYON_REGISTRY_PATH=registry.json
TACHYON_FORGE_PATH=forge
TACHYON_SOLC_PATH=
PAXEER_RPC_URL=

# Transport auth: when set, every request must send `Authorization: Bearer <token>`.
TACHYON_AUTH_TOKEN=

# Wallet (overrides [wallet] in the kvx). mode = self_hosted | embedded
TACHYON_WALLET_MODE=
# self_hosted: signer = raw | keystore | env
TACHYON_WALLET_SIGNER=
TACHYON_DEV_PRIVATE_KEY=
TACHYON_KEYSTORE_PATH=
TACHYON_KEYSTORE_PASSWORD=
# embedded (Matrix agent DID lane): no local keys
MATRIX_EXECUTOR_KEY=
PAXEER_WALLET_API=
# Never commit real private keys. Prefer ${ENV} references in tachyon.config.kvx.
