# MCL core module: confidence scoring
# Defines how the compiler aggregates per-slot confidences into an overall score.
# Used in pipeline stage 6. Loaded by mclc at startup.

§CONFIDENCE

# Per-slot weight in the aggregate.
# Slot weight is 1.0 if the slot value is fully resolved (matrix:// URI, typed, valid).
# Fractional if partially resolved or inferred.
slot.weight.fully_resolved=1.0
slot.weight.inferred=0.70
slot.weight.default_used=0.60
slot.weight.unknown_preferred=0.40
slot.weight.unknown_blocking=0.00

# Frame field weights — how much each Frame field contributes to overall confidence.
# Must sum to 1.0.
frame.weight.verb=0.30
frame.weight.objects=0.40
frame.weight.constraints=0.15
frame.weight.success_criteria=0.10
frame.weight.preferences=0.05

# Overall confidence = sum(frame.weight[field] * avg(slot.weight[slot] for slot in field))
formula=weighted_field_avg

# Thresholds (mirrored in pipeline.mtx for fast access — must stay in sync).
threshold.clarify=0.75       # below this: emit intent.clarify
threshold.auto_accept=0.90   # above this with zero blocking unknowns: skip clarify round

