# Deus control-plane environment template. Copy to /opt/deus/deus.env and fill
# real values (chmod 600). NEVER commit real secrets. See deus/internal/config
# for the full set; non-dev hard-requires are marked [required].

# --- Core ----------------------------------------------------------------
DEUS_PORT=9095
# [required] Direct (non-pooler) session connection over the supabase network.
DEUS_POSTGRES_URI=postgres://deus:CHANGE_ME@supabase-db:5432/deus?sslmode=disable

# --- Chain (Paxeer mainnet, chain 125) -----------------------------------
# [required] RPC endpoint.
PAXEER_RPC_URL=https://public-mainnet.rpcpaxeer.online/evm
DEUS_CHAIN_ID=125
# [required] Deployed addresses (filled after the on-chain deploy step).
DEUS_SERVICE_REGISTRY_ADDR=0x...
DEUS_SETTLEMENT_ANCHOR_ADDR=0x...

# --- Object store (dedicated MinIO sidecar, see docker-compose.yml) -------
# [required] Host[:port] only (scheme is stripped); UseSSL toggles TLS.
# MinIO root creds double as the Deus S3 creds (single-tenant).
MINIO_ROOT_USER=deus
MINIO_ROOT_PASSWORD=CHANGE_ME
DEUS_OBJSTORE_ENDPOINT=deus-minio:9000
DEUS_OBJSTORE_ACCESS_KEY=deus
DEUS_OBJSTORE_SECRET_KEY=CHANGE_ME
DEUS_OBJSTORE_BUCKET=deus-artifacts
DEUS_OBJSTORE_USE_SSL=false

# --- Signing / settlement keys (secret material) -------------------------
# [required] EIP-712 receipt/voucher signer (generated fresh on the box).
DEUS_GATEWAY_SIGNING_KEY=0x...
# Settler broadcasts settlement anchoring on chain 125 (must hold PAX gas).
DEUS_SETTLER_PRIVATE_KEY=0x...

# --- Wallet (caller spend, embedded Paxeer wallet) -----------------------
# [required] Callers pay through their embedded wallet under spend policy.
MATRIX_WALLET_API_URL=https://connect.paxportwallet.com

# --- Optional / deferred -------------------------------------------------
# Plain-language semantic search; unset => lexical-only discovery.
# DEUS_EMBED_ENDPOINT=
# DEUS_EMBED_MODEL=nomic-embed-text-v1.5
# Paxeer Cloud (Appwrite) hosted listings; unset => hosted listings disabled.
# DEUS_APPWRITE_ENDPOINT=
# DEUS_APPWRITE_PROJECT_ID=
# DEUS_APPWRITE_API_KEY=
# DEUS_HOSTING_KILL_SWITCH=false
