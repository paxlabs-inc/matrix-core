# fly.toml.tmpl — per-user Matrix daemon Machine.
#
# This is a TEMPLATE rendered by the router's provisioning code when a
# new Supabase user signs up. The router substitutes:
#
#   {{APP_NAME}}        e.g. matrix-daemon
#   {{REGION}}          e.g. iad / lhr / fra
#   {{IMAGE}}           e.g. registry.fly.io/matrix-daemon:<sha>
#   {{USER_ID}}         supabase user id, becomes MATRIX_USER_ID env
#   {{VOLUME_NAME}}     unique per user, e.g. mxdata_<user-id-trim>
#
# Run-of-the-mill `fly deploy` against this file is NOT how production
# works — production provisions Machines individually via the Machines
# API. This file IS used for the initial app creation:
#
#   fly apps create matrix-daemon
#   fly deploy --config deploy/daemon/fly.toml.tmpl --no-deploy
#
# After that the router takes over via POST /v1/apps/<app>/machines.

app = "{{APP_NAME}}"
primary_region = "{{REGION}}"
kill_signal = "SIGINT"
kill_timeout = "60s"

[build]
dockerfile = "deploy/daemon/Dockerfile"

[env]
MATRIX_DATA_DIR = "/data"
MATRIX_HOME     = "/opt/matrix"
# MATRIX_S3_ENDPOINT, MATRIX_S3_BUCKET, MATRIX_S3_KEY, MATRIX_S3_SECRET,
# MATRIX_USER_ID, MATRIX_DEFAULT_SKILL, MATRIX_COMPILER_MODEL,
# MATRIX_EXECUTOR_MODEL, MATRIX_DAEMON_TOKEN, FIREWORKS_API_KEY,
# TOGETHER_API_KEY  -- all injected as Fly secrets per Machine.

[[mounts]]
source      = "{{VOLUME_NAME}}"
destination = "/data"
initial_size = "10gb"

[[services]]
internal_port = 8080
protocol      = "tcp"
auto_stop_machines  = "suspend"
auto_start_machines = true
min_machines_running = 0

  [[services.ports]]
  port     = 80
  handlers = ["http"]
  force_https = true

  [[services.ports]]
  port     = 443
  handlers = ["tls", "http"]

  [[services.http_checks]]
  interval        = "30s"
  grace_period    = "20s"
  method          = "get"
  path            = "/healthz"
  protocol        = "http"
  timeout         = "5s"
  tls_skip_verify = false

[checks]
  [checks.boot]
    type     = "http"
    port     = 8080
    method   = "GET"
    path     = "/healthz"
    interval = "30s"
    timeout  = "5s"
    grace_period = "30s"

[[vm]]
size      = "shared-cpu-1x"
memory_mb = 1024
cpu_kind  = "shared"
cpus      = 1
