# uwacd environment — copy to .env (gitignored). Env overrides uwac.config.kvx.

# --- server ---
UWAC_ADDR=:8646
UWAC_ENV=development                       # set to anything else (or unset) in prod
UWAC_PUBLIC_BASE_URL=http://localhost:8646 # base for the OAuth redirect_to (GoTrue allowlist)
MATRIX_UWAC_TOKEN=                         # shared transport bearer (router injects this to daemons)

# --- token vault (AES-256-GCM) ---
UWAC_VAULT_KEY=                            # REQUIRED in prod. openssl rand -hex 32
UWAC_DATABASE_URI=                         # postgres://... (empty => in-memory, dev only)

# --- GoTrue (Supabase) we extend for scope-elevation PKCE ---
UWAC_SUPABASE_URL=
UWAC_SUPABASE_ANON_KEY=

# --- provider OAuth client creds (needed to REFRESH provider tokens; GoTrue does not) ---
# Use the SAME OAuth client GoTrue is configured with for Google.
UWAC_GOOGLE_CLIENT_ID=
UWAC_GOOGLE_CLIENT_SECRET=
