### comparison.index (`.kvx`)

compare.A1 {
  family="DeepSeek V4 Pro"
  fireworks_model=D1
  together_model=R1
  fireworks_price=$1.74/Muncached | $0.15/Mcached | $3.48/Moutput
  together_price=$2.10/Minput | $0.20/Mcached | $4.40/Moutput
  state=fireworks_lower_uncached_and_output
  status=[DONE]
}

compare.A2 {
  family="Kimi K2.6"
  fireworks_model=D2
  together_model=R3
  fireworks_price=$0.95/Muncached | $0.16/Mcached | $4.00/Moutput
  together_price=$1.20/Minput | $0.20/Mcached | $4.50/Moutput
  state=fireworks_lower_uncached_cached_and_output
  status=[DONE]
}

compare.A3 {
  family="MiniMax M2.7"
  fireworks_model=D3
  together_model=R4
  fireworks_price=$0.30/Muncached | $0.06/Mcached | $1.20/Moutput
  together_price=$0.30/Minput | $0.06/Mcached | $1.20/Moutput
  state=price_match
  status=[DONE]
}

compare.A4 {
  family="GLM 5.1"
  fireworks_model=D5
  together_model=R2
  fireworks_price=$1.40/Muncached | $0.26/Mcached | $4.40/Moutput
  together_price=$1.40/Minput | $4.40/Moutput
  state=input_output_match | fireworks_has_cached_price
  status=[DONE]
}

compare.A5 {
  family="OpenAI GPT-OSS 120B"
  fireworks_model=D7
  together_model=R8
  fireworks_price=$0.15/Muncached | $0.01/Mcached | $0.60/Moutput
  together_price=$0.15/Minput | $0.60/Moutput
  state=input_output_match | fireworks_has_cached_price
  status=[DONE]
}

compare.A6 {
  family="Qwen3.6 Plus"
  fireworks_model=D4
  together_model=none
  state=fireworks_only
  status=[OPEN]
}

compare.A7 {
  family="DeepSeek V4 Flash"
  fireworks_model=D9
  together_model=none
  state=fireworks_only
  status=[OPEN]
}

compare.A8 {
  family="OpenAI GPT-OSS 20B"
  fireworks_model=none
  together_model=R9
  state=together_only
  status=[OPEN]
}

compare.A9 {
  family="LFM2-24B-A2B"
  fireworks_model=none
  together_model=Q7
  state=together_only
  status=[OPEN]
}


### routing.suggestions (`.kvx`)

route.S1 {
  intent="lowest cost large OSS general chat"
  preferred_model=R9
  provider=together_ai
  reason="OpenAI GPT-OSS 20B has $0.05/Minput | $0.20/Moutput"
  status=[DONE]
}

