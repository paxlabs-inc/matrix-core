# Workers Static Assets header rules (applies to files served from
# build/client). Hashed bundles and fonts are content-addressed -> immutable.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=86400

/legal/*
  Cache-Control: public, max-age=3600

/.well-known/*
  Cache-Control: public, max-age=3600
