{
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@/*": ["./app/*"],
      "@repo/shadcn-ui/lib/utils": ["./app/lib/utils.ts"],
      "@repo/shadcn-ui/components/ui/*": ["./components/ui/shadcn/*"],
      "@repo/smoothui/components/smooth-button": [
        "./components/ui/smoothui/smooth-button/index.tsx"
      ],
      "@smoothui/data": ["./app/lib/smoothui-data.ts"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  },
  "exclude": [
    "node_modules",
    "build",
    ".wrangler",
    "components/ui/smoothui/form",
    "components/ui/smoothui/select",
    "components/ui/smoothui/combobox",
    "components/ui/smoothui/footer-3",
    "components/ui/smoothui/footer-4",
    "components/ui/smoothui/github-stars-animation",
    "components/ui/smoothui/header-1",
    "components/ui/smoothui/header-2",
    "components/ui/smoothui/header-3",
    "components/ui/smoothui/header-4",
    "components/ui/smoothui/logo-cloud-1",
    "components/ui/smoothui/logo-cloud-2",
    "components/ui/smoothui/logo-cloud-3",
    "components/ui/smoothui/logo-cloud-4",
    "components/ui/smoothui/team-1",
    "components/ui/smoothui/team-2",
    "components/ui/smoothui/testimonials-1",
    "components/ui/smoothui/testimonials-2",
    "components/ui/smoothui/testimonials-3"
  ]
}
