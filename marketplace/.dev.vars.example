# Copy to .dev.vars for local `pnpm dev`. NEVER commit .dev.vars itself.
# Production values go via `wrangler secret put <NAME>` (see OPS_RUNBOOK.md).

# Local Deus backend: the fixtures mock (node mocks/deus-mock.mjs).
DEUS_API_URL=http://localhost:8787

# Any >=16-char value works locally; prod uses a generated secret.
SESSION_SECRET=dev-local-marketplace-secret

# Enables the no-password dev sign-in (refused outside ENVIRONMENT=development).
MARKETPLACE_DEV_AUTH=1

# Optional: Supabase OAuth (PKCE). Leave unset to use dev sign-in only.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Optional: Cloudflare Turnstile (bot protection). Unset disables the widget.
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
