# Copy to `.env` and fill in real values. `.env` itself is gitignored.
# Required keys depend on which subsystems you run; see comments below.

# --- LLM providers (compiler + executor models) ---------------------------
# MCL/llm/llm.go reads these. Provider routing rules:
#   - model names starting with `accounts/fireworks/`  -> FIREWORKS_API_KEY
#   - all other "<vendor>/<model>" forms               -> TOGETHER_API_KEY
# Required to run any non-dry-run `mclc compile` or `mcl-execute walk`.
FIREWORKS_API_KEY=
TOGETHER_API_KEY=

# Optional. Legacy / experimental fallback gateway. Not required for v1.
LLMAPI_AI_API_KEY=

# --- Embedder (cortex/embed/api_embedder.go) ------------------------------
# Reuses FIREWORKS_API_KEY by default (nomic-embed-text-v1.5).
# Set explicitly only if you point the embedder at a different gateway.
# MATRIX_EMBED_ENDPOINT=https://api.fireworks.ai/inference/v1/embeddings

# --- Daemon (executor/cmd/mcl-execute daemon) -----------------------------
# Opaque bearer token validated by /events, /messages, /intents, /shutdown.
# Leave empty to disable auth — local-dev only.
MATRIX_DAEMON_TOKEN=

# --- Deploy (deploy/) -----------------------------------------------------
# Fly.io provisioning + control plane.
FLY_API_KEY=

# Snapshot push/pull target (MinIO on the Paxeer storage box).
# Used by deploy/daemon/entrypoint.sh on boot pull.
# MATRIX_S3_ENDPOINT=https://s3.matrix.paxeer.app
# MATRIX_S3_BUCKET=matrix-state
# MATRIX_S3_ACCESS_KEY=
# MATRIX_S3_SECRET_KEY=
# MATRIX_USER_ID=
